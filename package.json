{
  "name": "rateio-contas",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "build:standalone": "npm run build && npm run prepare:standalone",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint .",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run --config src/test/config/vitest.unit.config.ts",
    "test:integration": "npm run test:db:prepare && vitest run --config src/test/config/vitest.integration.config.ts",
    "test:db:prepare": "tsx src/test/scripts/prepare-test-db.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "prisma generate --schema src/server/db/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema src/server/db/prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema src/server/db/prisma/schema.prisma",
    "db:seed": "tsx src/server/db/prisma/seed.ts",
    "db:studio": "prisma studio --schema src/server/db/prisma/schema.prisma",
    "postinstall": "prisma generate --schema src/server/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "next": "16.2.4",
    "next-auth": "5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "prisma": "6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "seed": "tsx src/server/db/prisma/seed.ts"
  }
}
